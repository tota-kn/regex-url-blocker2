{
  "name": "regex-url-guard",
  "version": "0.0.0",
  "private": true,
  "description": "manifest.json description",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:browser": "node scripts/dev.mjs",
    "build": "wxt build",
    "zip": "wxt zip",
    "postinstall": "wxt prepare",
    "typecheck": "vue-tsc --noEmit",
    "lint": "oxlint && oxfmt --check",
    "lint:fix": "oxlint --fix && oxfmt --write",
    "format": "oxfmt --write",
    "format:check": "oxfmt --check",
    "lint:design": "pnpx @google/design.md lint DESIGN.md",
    "test:unit": "vitest",
    "test:e2e": "wxt build && playwright test",
    "test:e2e:ui": "wxt build && playwright test --ui"
  },
  "devDependencies": {
    "@heroicons/vue": "^2.2.0",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.2.4",
    "@vitejs/plugin-vue": "^5.2.4",
    "@vitest/coverage-v8": "^3.2.4",
    "@wxt-dev/module-vue": "^1.0.3",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0",
    "tailwindcss": "^4.2.4",
    "typescript": "5.6.3",
    "vitest": "^3.2.4",
    "vue": "^3.5.33",
    "vue-tsc": "^2.2.12",
    "wxt": "^0.19.29"
  }
}
