{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "categories": {
    "correctness": "error"
  },
  "env": {
    "browser": true,
    "webextensions": true
  },
  "plugins": ["eslint", "typescript", "unicorn", "oxc", "vue"],
  "options": {
    "denyWarnings": true,
    "reportUnusedDisableDirectives": "error",
    "respectEslintDisableDirectives": false
  }
}
