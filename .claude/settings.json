{
  "permissions": {
    "allow": [
      "Bash(pnpm test:unit *)",
      "Bash(pnpm test:e2e *)",
      "Bash(pnpm lint *)",
      "Bash(pnpm typecheck)",
      "Bash(pnpm dev)",
      "Bash(pnpm build)",
      "Read(//home/yt/.claude/skills/**)",
      "Read(//home/yt/.agents/skills/**)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "pnpm lint:fix 1>&2 || exit 2",
            "timeout": 120,
            "statusMessage": "Running pnpm lint:fix"
          },
          {
            "type": "command",
            "command": "pnpm typecheck 1>&2 || exit 2",
            "timeout": 120,
            "statusMessage": "Running pnpm typecheck"
          },
          {
            "type": "command",
            "command": "pnpm lint:design 1>&2 || exit 2",
            "timeout": 300,
            "statusMessage": "Running design.md lint"
          }
        ]
      }
    ]
  }
}
